frontend/dist/

# Database — lives on the server, not in git
backend/data/
backend/*.db
backend/*.db-shm
backend/*.db-wal
backend/*.db.lock
backend/*_backup*
backend/*_recovered*

# Uploads — user files, not in git
backend/uploads/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Claude Code local config
.claude/
